# Node Configuration
NODE_001_ID=node_001
NODE_002_ID=node_002

# Venv Paths
NODE_001_VENV_PATH=/tmp/venv1
NODE_002_VENV_PATH=/tmp/venv2

# Python Executables
NODE_001_PYTHON_EXECUTABLE=python3
NODE_002_PYTHON_EXECUTABLE=python3

# IP Configuration
NODE_001_SELF_IP=192.168.1.100
NODE_002_SELF_IP=192.168.1.101

# IP Masks
NODE_001_IP_MASK=255.255.255.0
NODE_002_IP_MASK=255.255.255.0

# Gateways
NODE_001_GATEWAY=192.168.1.1
NODE_002_GATEWAY=192.168.1.1

# Connectors
NODE_001_CONNECTORS=connector_a,connector_b
NODE_002_CONNECTORS=connector_c,connector_d

# URI for IP Updates
NODE_001_URI=
NODE_002_URI=

# Localhost Endpoint
LOCALHOST_ENDPOINT=http://127.0.0.1:8080
LOCALHOST_PORT=8080

# Gateway List for Route Matching
GATEWAY_LIST=192.168.1.1,192.168.1.254,10.0.0.1

# Library Path for Source Object Query
LIBRARY_PATH=/usr/local/lib/python3.x/site-packages
SOURCE_OBJECT_QUERY_PATTERN=*.py

# Credentials
NODE_001_CREDENTIALS_KEY=value123
NODE_002_CREDENTIALS_KEY=value456

# Self Node (for self-originating IP logic)
SELF_NODE_ID=node_002

# Cache Configuration
CACHE_DIR_PREFIX=cache_
DUMP_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# Gateway Timeout
GATEWAY_TIMEOUT=2

# Venv Fetch Timeout
VENV_FETCH_TIMEOUT=10
